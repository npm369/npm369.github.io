# Supabase database access. Keep service role key on the backend only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public site URL used by emails and redirects.
PUBLIC_SITE_URL=https://nmp.github.io

# SMTP email delivery. Use your email provider/app password here, never inside HTML.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="PowerMind <no-reply@yourdomain.com>"

# Long random secret used to hash verification OTPs before storing them.
OTP_SECRET=replace-with-a-long-random-secret

# Payment webhook shared secret.
PAYMENT_WEBHOOK_SECRET=make-a-long-random-secret
